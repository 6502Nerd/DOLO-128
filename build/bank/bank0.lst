                             ;*  To handle WDC65c51 bug on transmit, use a del
                             ;*  to ensure byte is transmitted before the next
                             ;*
                             ;************************************************
                             
                             	; ROM code
                             	code
                             
                             
                             ;****************************************
                             ;* ser_get_byte
                             ;* Get a byte (wait forever or just check)
                             ;* Input : C = 1 for synchronous, 0 for async
                             ;* Output : A = Byte code, C = 1 means A is inval
                             ;* Regs affected : P, A
                             ;****************************************
d29f :                       ser_get_byte
d29f : a502             [ 3] 	lda ser_first			; if first==last then buffer emp
d2a1 : 4503             [ 3] 	eor ser_last
d2a3 : d004             [ 3] 	bne ser_got_byte
d2a5 : b0f8             [ 3] 	bcs ser_get_byte
d2a7 : 38               [ 2] 	sec
d2a8 : 60               [ 6] 	rts
d2a9 :                       ser_got_byte
d2a9 : 5a               [ 3] 	phy
d2aa : a402             [ 3] 	ldy ser_first			; Get first byte in FIFO
d2ac : b90008           [ 4] 	lda ser_buf,y
d2af : e602             [ 5] 	inc ser_first			; Advance first byte of FIFO
d2b1 : 7a               [ 4] 	ply
d2b2 : 18               [ 2] 	clc						; Indicate byte was got
d2b3 : 60               [ 6] 	rts
                             
                             
                             ;****************************************
                             ;* ser_put_byte
                             ;* Put a byte out
