                             ;****************************************
d2b4 :                       ser_put_byte
d2b4 : 48               [ 3] 	pha						; Save A
                             ;	phx
                             ;	ldx #112				; Loop 112 times
d2b5 :                       ser_put_byte_wait				; Delay 2512 cycles (19200bp
                             ;	nop						; For 5.36Mhz clock
                             ;	nop						; ~25 cycles per loop (10xnop+dex+bne)
                             ;	nop						; 
                             ;	nop						; 
                             ;	nop						; 
                             ;	nop						; 
                             ;	nop						; 
                             ;	nop						; 
