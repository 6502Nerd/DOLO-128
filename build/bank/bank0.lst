d63c : c8               [ 2] 	iny
d63d : a208             [ 2] 	ldx #RTC_MTH
d63f : 20a4d4           [ 6] 	jsr rtc_read
d642 : 9133             [ 5] 	sta (tmp_v1),y
d644 : c8               [ 2] 	iny
d645 : a209             [ 2] 	ldx #RTC_YR
d647 : 20a4d4           [ 6] 	jsr rtc_read
d64a : 9133             [ 5] 	sta (tmp_v1),y
d64c : 4c27d5           [ 3] 	jmp rtc_resumeupdate
                             
                             ;**************************************
                             ;* rtc_nvvalid
                             ;* Validate nvram checksum
                             ;* C=1 means ERROR
                             ;* Simple 8 bit sum of all bytes should
                             ;* result in a zero. Partial sum carry
                             ;* is used.
                             ;* Uses A,X
                             ;**************************************
d64f :                       rtc_nvvalid
d64f : a20e             [ 2] 	ldx #14
d651 : a900             [ 2] 	lda #0
d653 : 8533             [ 3] 	sta tmp_v1
d655 :                       rtc_nvvalid_loop
d655 : 20a4d4           [ 6] 	jsr rtc_read
d658 : 18               [ 2] 	clc
d659 : 6533             [ 3] 	adc tmp_v1
d65b : 8533             [ 3] 	sta tmp_v1
d65d : e8               [ 2] 	inx
d65e : e040             [ 2] 	cpx #NV_RAMSZ+1
d660 : d0f3             [ 3] 	bne rtc_nvvalid_loop
d662 : a533             [ 3] 	lda tmp_v1
AS65 Assembler for R6502 [1.42].                                     Page   84
---------------------------------- bank0.s -----------------------------------

                             	; A-1 will be C=1 if A>=1
d664 : c901             [ 2] 	cmp #1
d666 : 60               [ 6] 	rts
                             
                             ;**************************************
                             ;* rtc_nvwrite
                             ;* Write to nvram location X, value A
                             ;* Checksum (byte 127) is also updated
                             ;**************************************
d667 :                       rtc_nvwrite
                             	; Write to required nv location
d667 : 209ad4           [ 6] 	jsr rtc_write
                             	; Zero out checksum location
d66a : a23f             [ 2] 	ldx #NV_RAMSZ
d66c : a900             [ 2] 	lda #0
d66e : 209ad4           [ 6] 	jsr rtc_write
                             	; Get new checksum by calling validator
d671 : 204fd6           [ 6] 	jsr rtc_nvvalid
                             	; Calculate checksum by making 2s complement
d674 : 49ff             [ 2] 	eor #0xff
d676 : 18               [ 2] 	clc
d677 : 6901             [ 2] 	adc #1
                             	; Write new checksum
d679 : a23f             [ 2] 	ldx #NV_RAMSZ
d67b : 209ad4           [ 6] 	jsr rtc_write
d67e : 60               [ 6] 	rts
                             
                             ;**************************************
                             ;* rtc_nvread
                             ;* Read from nvram location X
                             ;* Value in A
                             ;* C=1 if checksum failed
                             ;**************************************
d67f :                       rtc_nvread
                             	; Read nv location
d67f : 20a4d4           [ 6] 	jsr rtc_read
                             	; Remember while validating checksum
d682 : 48               [ 3] 	pha
                             	; Validate checksum (C=0 if OK)
d683 : 204fd6           [ 6] 	jsr rtc_nvvalid
                             	; Retrieve the location read
d686 : 68               [ 4] 	pla
                             	; C=0 if OK and A is valid
d687 : 60               [ 6] 	rts
                             
