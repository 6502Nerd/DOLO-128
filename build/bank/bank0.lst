d6a5 : 1f                    	db 0x1f				; R8 = Channel A Vol
d6a6 : 1f                    	db 0x1f				; R9 = Channel B Vol
d6a7 : 1f                    	db 0x1f				; R10 = Channel C Vol
d6a8 : 00                    	db 0x00				; R11 = Envelope Period Low
d6a9 : 09                    	db 0x09				; R12 = Envelope Period High
d6aa : 00                    	db 0b00000000		; R13 = Envelope Shape : 0000
d6ab : 00                    	db 0x00				; R14 = IO Port A
d6ac : 00                    	db 0x00				; R15 = IO Port B ; Initialise to 0
                             
