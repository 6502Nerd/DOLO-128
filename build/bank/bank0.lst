d21f :                       set_led0
d21f : 48               [ 3] 	pha							; Save A
d220 : ad0004           [ 4] 	lda IO_0 + PRB				; Get current led status
d223 : 0902             [ 2] 	ora #KB_LED0					; Initially assume off
d225 : 9002             [ 3] 	bcc skip_led0_on
d227 : 4902             [ 2] 	eor #KB_LED0					; Switch on if C=1
d229 :                       skip_led0_on
d229 : 8d0004           [ 4] 	sta IO_0 + PRB				; Set the leds
d22c : 68               [ 4] 	pla							; Restore A
d22d : 60               [ 6] 	rts
                             
