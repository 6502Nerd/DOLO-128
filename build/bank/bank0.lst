c5a8 :                       io_active_device		; Entry point for A set
c5a8 : 0a               [ 2] 	asl	a				; x16 the Block number
c5a9 : 0a               [ 2] 	asl a
c5aa : 0a               [ 2] 	asl a
c5ab : 0a               [ 2] 	asl a
c5ac : a8               [ 2] 	tay
c5ad : a200             [ 2] 	ldx #0
                             	; Copy device settings to io block
c5af :                       io_copy_data
c5af : b923c6           [ 4] 	lda io_devices,y
c5b2 : 9d4e0c           [ 5] 	sta io_block,x
c5b5 : c8               [ 2] 	iny
c5b6 : e8               [ 2] 	inx
c5b7 : e010             [ 2] 	cpx #io_struct
c5b9 : d0f4             [ 3] 	bne io_copy_data
                             	
c5bb : a90d             [ 2] 	lda #UTF_CR		; Line terminator is CR
c5bd : 853e             [ 3] 	sta buf_ef
c5bf : 60               [ 6] 	rts
                             
