                             ;* io_read_line
                             ;* Read a line, terminated by terminating char or
                             ;* Input : buf_(sz/ef) : Address, Max size, end m
                             ;*		    X,A = destination (uses buf_adr)
                             ;*		    Y=max line length
                             ;* Output : Y = Line length C = Buffer limit reac
AS65 Assembler for R6502 [1.42].                                     Page   28
---------------------------------- bank3.s -----------------------------------

                             ;* Regs affected : None
                             ;****************************************
c5d2 :                       io_read_line
c5d2 : 863b             [ 3] 	stx buf_adr			; Save pointer to storage
c5d4 : 853c             [ 3] 	sta buf_adr+1
c5d6 : 843d             [ 3] 	sty buf_sz			; Max length
c5d8 : 08               [ 3] 	php					; Save echo state
c5d9 : a000             [ 2] 	ldy #0x00			; Starting at first byte
c5db :                       io_get_line_byte
c5db : 38               [ 2] 	sec					; Getting bytes synchronously
c5dc : 20c0c5           [ 6] 	jsr io_get_ch		; Get a byte
c5df : b026             [ 4] 	bcs io_get_line_done; Got nothing then finish
c5e1 : 28               [ 4] 	plp					; Get echo state
c5e2 : 08               [ 3] 	php					; Instantly save it back
c5e3 : 900c             [ 3] 	bcc io_skip_echo	; Carry not set = don't echo
c5e5 : c97f             [ 2] 	cmp #UTF_DEL		; Delete?
c5e7 : d005             [ 3] 	bne io_do_echo
c5e9 : c000             [ 2] 	cpy #0				; Already at beginning?
c5eb : f004             [ 3] 	beq io_skip_echo	; Don't echo delete
c5ed : 88               [ 2] 	dey					; Else decrement length
c5ee :                       io_do_echo
c5ee : 20c3c5           [ 6] 	jsr io_put_ch		; Echo it
c5f1 :                       io_skip_echo
c5f1 : c920             [ 2] 	cmp #UTF_SPECIAL	; Special character?
c5f3 : 9007             [ 3] 	bcc io_skip_special	; Skip if so (don't add to b
c5f5 : c97f             [ 2] 	cmp #UTF_DEL		; Don't proces DEL either
c5f7 : f003             [ 3] 	beq io_skip_special
c5f9 : 913b             [ 5] 	sta (buf_adr),y		; Save it
c5fb : c8               [ 2] 	iny					; Increase length
c5fc :                       io_skip_special
c5fc : c53e             [ 3] 	cmp buf_ef			; Is it the terminating char?
c5fe : f007             [ 4] 	beq io_get_line_done	; If yes then done
c600 : c43d             [ 3] 	cpy buf_sz			; Reached the buffer max size?
c602 : d0d7             [ 4] 	bne io_get_line_byte	; No, get another byte
c604 : 28               [ 4] 	plp					; Remember to pull echo state off stack
c605 : 38               [ 2] 	sec					; Yes, set carry flag
c606 : 60               [ 6] 	rts					; And done
c607 :                       io_get_line_done
c607 : a900             [ 2] 	lda #0
c609 : 913b             [ 5] 	sta (buf_adr),y		; Terminate with 0
c60b : 28               [ 4] 	plp					; Remember to pull echo state off stack
c60c : 18               [ 2] 	clc					; Clear carry flag
c60d : 60               [ 6] 	rts					; Fin
                             
                             ;****************************************
                             ;* io_print_line
                             ;* Print a line (when data is not already in seri
                             ;* Input : X = Address Lo, A = Address Hi
                             ;* Output : Y=number chars output
                             ;* Regs affected : All
                             ;****************************************
c60e :                       io_print_line
c60e : 48               [ 3] 	pha
                             
