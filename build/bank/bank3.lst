d912 :                       FIX16BITS       ; INT(256*2*1000/1773) = 289 = 25
                                             ; Homebrew is 1.34Mhz
                                             ; So calculation = 386 = 256 + 12
                                             ; IN:  register A is low byte
                                             ;      register X is high byte
                                             ; OUT: register Y is low byte
                                             ;      register X is high byte
                             
d912 : 86f8             [ 3]         stx TA1         ; Reg 1 = 256*AX
d914 : 85fa             [ 3]         sta TB1
d916 : 86f9             [ 3]         stx TA2         ; Reg 2 = 256*AX
d918 : 85fb             [ 3]         sta TB2
d91a : 64fd             [ 3]         stz TC2
d91c : 86fe             [ 3]         stx TB3         ; Reg 3 = AX
d91e : 85ff             [ 3]         sta TC3
                                     
                                     ; x128 for homebrew
                                     ; which is same as right shift 1 time of 
d920 : 46f9             [ 5]         lsr TA2
d922 : 66fb             [ 5]         ror TB2
d924 : 66fd             [ 5]         ror TC2
                                             
