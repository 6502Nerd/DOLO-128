d944 : 65fa             [ 3]         adc TB1
d946 : a8               [ 2]         tay         ; sta TB1
d947 : a5f9             [ 3]         lda TA2
d949 : 65f8             [ 3]         adc TA1
                                     ; sta TA1
                             
