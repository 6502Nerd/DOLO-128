                             ; HB-BBC-128 settings:
                             ;* AY-3-8910 definitions
                             ;* The sound chip is accessed through VIA 2
0480 =                       IO_1		= 0x0480
0000 =                       PRB		= 0x00
0001 =                       PRA		= 0x01
0002 =                       DDRB		= 0x02
0003 =                       DDRA		= 0x03
0481 =                       SND_ADBUS	= IO_1+PRA
0480 =                       SND_MODE	= IO_1+PRB
                             
0040 =                       SND_SELREAD		= 0x40
0002 =                       SND_SELWRITE		= 0x02
0042 =                       SND_SELSETADDR		= (SND_SELREAD|SND_SELWRITE)
00bd =                       SND_DESELECT_MASK	= (0xff-SND_SELREAD-SND_SELWRIT
                             
                             
                             ;****************************************
                             ;* ay_set
                             ;* Set AY register A to value X
                             ;* Input : A = Reg no, X = Value
                             ;* Output : None
                             ;* Regs affected : None
                             ;****************************************
d951 :                       ay_set
d951 : 48               [ 3]         pha
                             
d952 : a9ff             [ 2] 	lda #0xff			; Set Port A to output
d954 : 8d8304           [ 4] 	sta IO_1 + DDRA
                             
d957 : 68               [ 4]         pla
d958 : 8d8104           [ 4] 	sta SND_ADBUS			; Put A on the sound bus (A = re
                             
d95b : ad8004           [ 4] 	lda SND_MODE			; Need to preserve contents of ot
d95e : 29bd             [ 2] 	and #SND_DESELECT_MASK	        ; Mask off mode b
d960 : 0942             [ 2] 	ora #SND_SELSETADDR		; Select AY mode to latch a
