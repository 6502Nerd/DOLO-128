c024 : ad0004           [ 4] 	lda IO_0+PRB
c027 : 293f             [ 2] 	and #ROM_ZMASK
c029 : 0501             [ 3] 	ora tmp_bank2
c02b : 8d0004           [ 4] 	sta IO_0+PRB
                             	
                             	; Restore A
c02e : a500             [ 3] 	lda tmp_bank1
                             
