                                     ; shift reg 3 left, the carry added to re
d926 : 06ff             [ 5]         asl TC3
d928 : 26fe             [ 5]         rol TB3
d92a : a5f9             [ 3]         lda TA2
d92c : 6900             [ 2]         adc #0
d92e : 85f9             [ 3]         sta TA2
                                     ; Now add the rest of reg 3 to reg 2
d930 : a5ff             [ 3]         lda TC3
d932 : 65fd             [ 3]         adc TC2
d934 : 85fd             [ 3]         sta TC2
d936 : a5fe             [ 3]         lda TB3
d938 : 65fb             [ 3]         adc TB2
d93a : 85fb             [ 3]         sta TB2
d93c : a900             [ 2]         lda #0
d93e : 65f9             [ 3]         adc TA2
d940 : 85f9             [ 3]         sta TA2
                             
                                     ; Add reg 2(x128+x2) to reg 1(x256) and t
