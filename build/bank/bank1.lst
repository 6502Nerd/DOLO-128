d4ca : 3cbd                  	db "<",'='+0x80					; Less than or equal
d4cc : 3ebd                  	db ">",'='+0x80					; Greater than or equal
d4ce : 3cbe                  	db "<",'>'+0x80					; Not equal
d4d0 : bc                    	db '<'+0x80						; Less than
d4d1 : be                    	db '>'+0x80						; Greater than
d4d2 : 3dbd                  	db "=",'='+0x80					; Equality (always last)
                             
d4d4 : 00                    	db  0
                             
                             
                             	
                             	
