                             ;****************************************
                             ;* df_tk_parsestatement
                             ;* Execute parse routine for this statement
                             ;* Input: df_tokoff is the token found
                             ;* Return: CC = Parsed ok, CS = Error
                             ;****************************************
d1ff :                       df_tk_exec_parser
d1ff : 0a               [ 2] 	asl a
d200 : aa               [ 2] 	tax
d201 : bdd5d4           [ 4] 	lda df_tk_tokenjmp,x
d204 : 85d7             [ 3] 	sta df_tmpptra
d206 : bdd6d4           [ 4] 	lda df_tk_tokenjmp+1,x
d209 : 85d8             [ 3] 	sta df_tmpptra+1
d20b : 6cd700           [ 6] 	jmp (df_tmpptra)
                             
                             
                             ;****************************************
                             ;* df_tk_linenum
                             ;* Tokenise line number
                             ;****************************************
d20e :                       df_tk_linenum
                             	; Convert line number to 16 bit number
                             	; Save the line number
                             	; Increment the buffer pointer
d20e : 18               [ 2] 	clc
d20f : a900             [ 2] 	lda #lo(df_linbuff)
d211 : 65b2             [ 3] 	adc df_linoff
d213 : aa               [ 2] 	tax
d214 : a90a             [ 2] 	lda #hi(df_linbuff)
d216 : 6900             [ 2] 	adc #0
d218 : a001             [ 2] 	ldy #1			; Decimal format only
d21a : 2047c9           [ 6] 	jsr con_n_to_a
d21d : 18               [ 2] 	clc
d21e : 8a               [ 2] 	txa
d21f : 65b2             [ 3] 	adc df_linoff
d221 : 85b2             [ 3] 	sta df_linoff
                             	; Now save line number
d223 : a579             [ 3] 	lda num_a
d225 : 20bcce           [ 6] 	jsr df_tk_put_tok
d228 : a57a             [ 3] 	lda num_a+1
d22a : 4cbcce           [ 3] 	jmp df_tk_put_tok
                             
                             ;****************************************
                             ;* df_tk_matchtok
                             ;* Try and find a token match against the table d
                             ;* Input:
                             ;*			Current df_linbuff and df_linoff
                             ;* Return: 	CC = No Error, CS = Error
                             ;*			df_linoff points to next char if CC else unc
                             ;*			df_symoff is the symbol table index
                             ;****************************************
d22d :                       df_tk_matchtok
                             	; save the mask to check types against
d22d : 48               [ 3] 	pha
                             	; Start at token symbols beginning
d22e : a9af             [ 2] 	lda #lo(df_tokensyms)
d230 : 85b7             [ 3] 	sta df_symtab
d232 : a9d2             [ 2] 	lda #hi(df_tokensyms)
d234 : 85b8             [ 3] 	sta df_symtab+1
