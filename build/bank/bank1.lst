f353 : 18               [ 2] 	clc
f354 : 65aa             [ 3] 	adc df_starend
f356 : 85aa             [ 3] 	sta df_starend
f358 : 68               [ 4] 	pla
f359 : 65ab             [ 3] 	adc df_starend+1
f35b : 85ab             [ 3] 	sta df_starend+1
                             	; return old starend as start of space
f35d : 68               [ 4] 	pla
f35e : aa               [ 2] 	tax
f35f : 68               [ 4] 	pla
f360 : 60               [ 6] 	rts
                             	
                             
