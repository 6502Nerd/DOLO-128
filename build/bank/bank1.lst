                             	include "dflat/stack.s"
                             ;************************************************
                             ;*
                             ;*	BBC-128
                             ;*	Dolo Miah (@6502Nerd)
                             ;*	Copyright (c) 2020
                             ;*  Free to use for any non-commercial purpose su
                             ;*  credit of original my authorship please!
                             ;*
                             ;*  STACK.S
                             ;*  This module implements the dflat software sta
                             ;*  needs a few stacks:
                             ;*  - 6502 stack for expression parsing and reent
                             ;*  - dflat runtime stack for things like for/nex
                             ;*  - dflat parameter stack for passing parameter
                             ;*  The two software stacks are implemented in th
                             ;*  with the operator stack growing up from 0 and
                             ;*  runtime stack growing down from 255.  Hopeful
                             ;*  don't meet as there are no checks for this at
                             ;*  purely because I want speed over friendliness
                             ;*  I may come to regret this!
                             ;*  I have also added the only runtime memory all
                             ;*  needed by dflat here.  Humourously I have cal
                             ;*  which is taken from the C language, but it's 
                             ;*  grab some memory after end the of dflat progr
                             ;*  arrays - which of course cannot have storage 
                             ;*  tokenisation time (e.g. because I dimension a
                             ;*  a size from a variable).
                             ;*
                             ;************************************************
AS65 Assembler for R6502 [1.42].                                     Page  193
---------------------------------- bank1.s -----------------------------------

                             
                             	; ROM code
                             	code  
                             
                             
                             ;****************************************
                             ;* Push a byte on to runtime stack
                             ;* A = byte
                             ;****************************************
f2ce :                       df_rst_pushByte
f2ce : a4ac             [ 3] 	ldy df_rtstop
f2d0 : 99000b           [ 5] 	sta df_rtstck,y
f2d3 : 88               [ 2] 	dey
f2d4 : 84ac             [ 3] 	sty df_rtstop
f2d6 : 60               [ 6] 	rts
                             
                             ;****************************************
                             ;* Pop a byte off runtime stack
                             ;* A = byte
                             ;****************************************
f2d7 :                       df_rst_popByte
f2d7 : a4ac             [ 3] 	ldy df_rtstop
f2d9 : c8               [ 2] 	iny
f2da : b9000b           [ 4] 	lda df_rtstck,y
f2dd : 84ac             [ 3] 	sty df_rtstop
f2df : 60               [ 6] 	rts
                             
                             ;****************************************
                             ;* Peek a byte off runtime stack
                             ;* A = byte
                             ;****************************************
f2e0 :                       df_rst_peekByte
f2e0 : a4ac             [ 3] 	ldy df_rtstop
                             	; Look at what is below top of stack
                             	; below means the next address up as
                             	; this stack grows downwards like 6502
f2e2 : b9010b           [ 4] 	lda df_rtstck+1,y
f2e5 : 60               [ 6] 	rts
                             	
                             ;****************************************
                             ;* Push a word on to runtime stack
                             ;* X,A = word lo,hi
                             ;****************************************
f2e6 :                       df_rst_pushWord
f2e6 : a4ac             [ 3] 	ldy df_rtstop
f2e8 : 99000b           [ 5] 	sta df_rtstck,y
f2eb : 88               [ 2] 	dey
f2ec : 8a               [ 2] 	txa
f2ed : 99000b           [ 5] 	sta df_rtstck,y
f2f0 : 88               [ 2] 	dey
f2f1 : 84ac             [ 3] 	sty df_rtstop
f2f3 : 60               [ 6] 	rts
                             
                             ;****************************************
                             ;* Pop a word off runtime stack
                             ;* X,A = word lo,hi
                             ;****************************************
f2f4 :                       df_rst_popWord
f2f4 : a4ac             [ 3] 	ldy df_rtstop
f2f6 : c8               [ 2] 	iny
f2f7 : be000b           [ 4] 	ldx df_rtstck,y
f2fa : c8               [ 2] 	iny
AS65 Assembler for R6502 [1.42].                                     Page  194
---------------------------------- bank1.s -----------------------------------

f2fb : b9000b           [ 4] 	lda df_rtstck,y
f2fe : 84ac             [ 3] 	sty df_rtstop
f300 : 60               [ 6] 	rts
                             
                             ;****************************************
                             ;* Push a string pointer on to parm stack
                             ;* X,A - int
                             ;****************************************
f301 :                       df_ost_pushStr
f301 : a004             [ 2] 	ldy #DFST_STR
f303 : d009             [ 3] 	bne df_ost_pushParmX		; ALWAYS!
                             
                             ;****************************************
                             ;* Push a general pointer on to parm stack
                             ;* X,A - int
                             ;****************************************
f305 :                       df_ost_pushPtr
f305 : a0ff             [ 2] 	ldy #DFST_PTR
f307 : d005             [ 3] 	bne df_ost_pushParmX		; ALWAYS!
                             	
                             ;****************************************
                             ;* Push A on to parm stack
                             ;* X,A - int
                             ;****************************************
f309 :                       df_ost_pushIntA
f309 : aa               [ 2] 	tax
f30a : a900             [ 2] 	lda #0
                             	; ***FALLS THROUGH TO NEXT ROUTINE***
                             
                             ;****************************************
                             ;* Push an int on to parm stack
                             ;* X,A - int
                             ;****************************************
f30c :                       df_ost_pushInt
f30c : a003             [ 2] 	ldy #DFST_INT
                             	; ***FALLS THROUGH TO NEXT ROUTINE***
                             
                             ;****************************************
                             ;* Push a parameter on to parm stack
                             ;* X,A - int
                             ;* Y - type
                             ;****************************************
f30e :                       df_ost_pushParmX
f30e : 48               [ 3] 	pha				; Save A
f30f : 5a               [ 3] 	phy				; Save Y
                             ;	sty tmp_d		; Save Type
f310 : a4ad             [ 3] 	ldy df_parmtop	; Get stack index
                             	; push high byte first (A)
f312 : 99000b           [ 5] 	sta df_rtstck,y
f315 : c8               [ 2] 	iny
                             	; push low byte next (X)
f316 : 8a               [ 2] 	txa
f317 : 99000b           [ 5] 	sta df_rtstck,y
f31a : c8               [ 2] 	iny
                             ;	lda tmp_d		; get Type
f31b : 68               [ 4] 	pla				; Get Type
f31c : 99000b           [ 5] 	sta df_rtstck,y
f31f : c8               [ 2] 	iny
                             	; save new top of stack
f320 : 84ad             [ 3] 	sty df_parmtop
f322 : 68               [ 4] 	pla				; restore A
f323 : 60               [ 6] 	rts
AS65 Assembler for R6502 [1.42].                                     Page  195
---------------------------------- bank1.s -----------------------------------

                             
                             ;****************************************
                             ;* Pop a string pointer off parm stack
                             ;* X,A - int
                             ;****************************************
f324 :                       df_ost_popStr
f324 : a904             [ 2] 	lda #DFST_STR
f326 : d006             [ 3] 	bne df_ost_popParmX			; ALWAYS!
                             	
                             ;****************************************
                             ;* Pop a general pointer off parm stack
                             ;* X,A - int
                             ;****************************************
f328 :                       df_ost_popPtr
f328 : a9ff             [ 2] 	lda #0xff
f32a : d002             [ 3] 	bne df_ost_popParmX			; ALWAYS!
                             		
                             ;****************************************
                             ;* Pop an int off parm stack
                             ;* X,A - int
                             ;****************************************
f32c :                       df_ost_popInt
f32c : a903             [ 2] 	lda #DFST_INT
                             	; ***FALL THROUGH TO NEXT ROUTINE***
                             
                             ;****************************************
                             ;* Pop parameter from the stack
                             ;* X,A - int
                             ;* A - type expected
                             ;****************************************
f32e :                       df_ost_popParmX
f32e : a4ad             [ 3] 	ldy df_parmtop
                             	; pull type first
f330 : 88               [ 2] 	dey
f331 : 39000b           [ 4] 	and df_rtstck,y
f334 : f00b             [ 3] 	beq df_st_typemismatcherr
                             	; pull low byte first
f336 : 88               [ 2] 	dey
f337 : be000b           [ 4] 	ldx df_rtstck,y
                             	; pull high byte next
f33a : 88               [ 2] 	dey
f33b : b9000b           [ 4] 	lda df_rtstck,y
                             	; save new top of stack
f33e : 84ad             [ 3] 	sty df_parmtop
f340 : 60               [ 6] 	rts
f341 :                       df_st_typemismatcherr
                             	SWBRK DFERR_TYPEMISM
                             
                             
                             ;****************************************
                             ;* Return type on top of stack
                             ;* A - type
                             ;****************************************
f343 :                       df_ost_peekType
f343 : a4ad             [ 3] 	ldy df_parmtop
f345 : b9ff0a           [ 4] 	lda df_rtstck-1,y
f348 : 60               [ 6] 	rts
                             
                             ;****************************************
                             ;* Allocate space on the heap
                             ;* X, A = Number of bytes to allocate
                             ;* X, A return address of allocated space
AS65 Assembler for R6502 [1.42].                                     Page  196
