                             ;****************************************
f349 :                       df_st_malloc
                             	; save A in Y
f349 : a8               [ 2] 	tay
                             	; save old starend
f34a : a5ab             [ 3] 	lda df_starend+1
f34c : 48               [ 3] 	pha
f34d : a5aa             [ 3] 	lda df_starend
f34f : 48               [ 3] 	pha
                             	; restore A from Y
f350 : 98               [ 2] 	tya
                             	; add X,A to starend
f351 : 48               [ 3] 	pha
