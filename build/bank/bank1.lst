                             ;****************************************
                             ;* io_init
                             ;* Initialise the default device and make active
                             ;* No keys pressed = serial (default)
                             ;* F0 pressed = KB/VDP
                             ;* F1 pressed = Serial
                             ;* Keyboard and screen or serial port
                             ;* Output : None
                             ;* Regs affected : P, A
                             ;****************************************
c589 :                       io_init
c589 : a900             [ 2] 	lda #0				; Assume it's serial
c58b : 48               [ 3] 	pha
c58c : 20a1c2           [ 6] 	jsr _kb_read_dip	; Check DIPs if 0xff then assum
c58f : 2910             [ 2] 	and #0x10
c591 : d00b             [ 3] 	bne io_init_set_default
c593 : 2089c2           [ 6] 	jsr _kb_read_raw	; Check pressed key
c596 : e081             [ 2] 	cpx #0x81			; f1 key pressed (i.e. boot up in se
c598 : f004             [ 3] 	beq io_init_set_default
                             	; Else set to KB/screen for IO
c59a : 68               [ 4] 	pla
c59b : a901             [ 2] 	lda #1
c59d : 48               [ 3] 	pha
c59e :                       io_init_set_default
c59e : 68               [ 4] 	pla
c59f : 8d4d0c           [ 4] 	sta io_default
c5a2 : 4ca5c5           [ 3] 	jmp io_set_default	; Activate the default device
                             
                             ;****************************************
                             ;* io_set_default, io_active_device
                             ;* Activate device based on default or A
                             ;* Input : A = Device number
