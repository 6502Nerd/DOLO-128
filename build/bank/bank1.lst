f3d7 : 4e6f20656e6469..      	db	"No endif", 0
f3e0 : 4e6f20696600          	db	"No if", 0
f3e6 : 4e6f20666f7200        	db	"No for", 0
f3ed : 4e6f7420666f75..      	db	"Not found", 0
f3f7 : 546f6f206c6f6e..      	db	"Too long", 0
f400 : 427265616b00          	db	"Break", 0
f406 : 4e6f206461746100      	db	"No data", 0
f40e : 4e6f207768696c..      	db	"No while", 0
