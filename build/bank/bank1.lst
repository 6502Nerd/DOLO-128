                             	include "dflat/toksubs.s"
                             ;************************************************
                             ;*
                             ;*	DOLO-1 HOMEBREW COMPUTER
                             ;*	Hardware and software design by Dolo Miah
                             ;*	Copyright 2014-18
                             ;*  Free to use for any non-commercial purpose su
                             ;*  full credit of original my authorship please!
                             ;*
                             ;*  TOKSUBS.S
                             ;*  Module that implements the tokenisation of ke
                             ;*  When a line is being parsed, the index of the
                             ;*  found in the symbol table is used to call a r
                             ;*  here.  The job of a routine here is then to f
                             ;*  parse the raw input e.g. a command that takes
                             ;*  parameters, need to do what it needs to ident
AS65 Assembler for R6502 [1.42].                                     Page   89
---------------------------------- bank1.s -----------------------------------

                             ;*  Despite the number of keywords in dflat, this
                             ;*  anywhere near the size of rtsubs.s (the runti
                             ;*  equivalent of this) because there is so much 
                             ;*  synactically.
                             ;*  The tokenised output is put in to its own buf
                             ;*  if the whole input was tokenised successfully
                             ;*  dflat will either try and execute (if in imme
                             ;*  mode), or save it to program memory in line n
                             ;*  order.
                             ;*
                             ;************************************************
                             
                             	; ROM code
                             	code  
                             
                             
                             ;* General routine to tokenise a mandatory variab
d649 :                       df_tk_variable
d649 : 200dcf           [ 6] 	jsr df_tk_skip_ws
                             	; tokenise a variable
d64c : 20abce           [ 6] 	jsr df_tk_peek_buf
d64f : 20f4ce           [ 6] 	jsr df_tk_isalpha
d652 : 901d             [ 3] 	bcc df_tk_error
d654 : a900             [ 2] 	lda #0
d656 : 60               [ 6] 	rts
                             
                             ;****************************************
                             ;* Parse assignment preamble
                             ;****************************************
d657 :                       df_tk_preassign
                             	; Put assignment token
                             	; assume its a numeric int for now
d657 : a980             [ 2] 	lda #0x80
d659 : 20bcce           [ 6] 	jsr df_tk_put_tok
                             	
                             	; first find or create a variable
d65c : 2049d6           [ 6] 	jsr df_tk_variable
d65f : 20f3cf           [ 6] 	jsr df_tk_var
                             	; next char sound be =
d662 : a93d             [ 2] 	lda #'='
d664 : 2048cf           [ 6] 	jsr df_tk_expect_tok_err
                             	; skip more ws
d667 : 200dcf           [ 6] 	jsr df_tk_skip_ws
                             	; should not be at end of line
d66a : 20abce           [ 6] 	jsr df_tk_peek_buf
d66d : f002             [ 3] 	beq df_tk_parse_ass_err
d66f : 18               [ 2] 	clc
d670 : 60               [ 6] 	rts
d671 :                       df_tk_parse_ass_err
d671 :                       df_tk_error
                             	SWBRK DFERR_SYNTAX
                             
                             
                             ;****************************************
                             ;* Parse numeric assignment
                             ;****************************************
d673 :                       df_tk_assign
d673 : 2057d6           [ 6] 	jsr df_tk_preassign
                             	; tokenise an expression (int or byte)
d676 : 203ad1           [ 6] 	jsr df_tk_expression
d679 : 18               [ 2] 	clc
d67a : 60               [ 6] 	rts
AS65 Assembler for R6502 [1.42].                                     Page   90
---------------------------------- bank1.s -----------------------------------

                             
                             
d67b :                       df_tk_comment
                             	; copy all subsequent chars to token
d67b : 20b1ce           [ 6] 	jsr df_tk_get_buf
d67e : f005             [ 3] 	beq df_tk_comment_done
d680 : 20bcce           [ 6] 	jsr df_tk_put_tok
d683 : 80f6             [ 3] 	bra df_tk_comment
d685 :                       df_tk_comment_done
d685 : 18               [ 2] 	clc
d686 : 60               [ 6] 	rts
                             
                             ; Utility to get procedure name with _
d687 :                       df_tk_listp_procname
                             	; try and find the first proc
d687 : a95f             [ 2] 	lda #'_'
d689 : 203dcf           [ 6] 	jsr df_tk_expect_tok
d68c : b01a             [ 3] 	bcs df_tk_listp_procname_err
                             	; now get first alpha then all alphanum
d68e : 20abce           [ 6] 	jsr df_tk_peek_buf
d691 : 20f4ce           [ 6] 	jsr df_tk_isalpha
d694 : 9012             [ 3] 	bcc df_tk_listp_procname_err
d696 :                       df_tk_listp_procname_ch
d696 : 20abce           [ 6] 	jsr df_tk_peek_buf
d699 : 2001cf           [ 6] 	jsr df_tk_isalphanum
d69c : 9008             [ 3] 	bcc df_tk_listp_procname_ok
d69e : 20b1ce           [ 6] 	jsr df_tk_get_buf
d6a1 : 20bcce           [ 6] 	jsr df_tk_put_tok
d6a4 : 80f0             [ 3] 	bra df_tk_listp_procname_ch
d6a6 :                       df_tk_listp_procname_ok
d6a6 : 18               [ 2] 	clc
d6a7 : 60               [ 6] 	rts
d6a8 :                       df_tk_listp_procname_err
d6a8 : 38               [ 2] 	sec
d6a9 : 60               [ 6] 	rts
                             
d6aa :                       df_tk_list
d6aa : 2087d6           [ 6] 	jsr df_tk_listp_procname
                             	; if not found try '*' or normal list
d6ad : b007             [ 3] 	bcs df_tk_list_procs
                             	; the '-' allows to list to end
d6af : a92d             [ 2] 	lda #'-'
                             	; find and add if it exists
d6b1 : 203dcf           [ 6] 	jsr df_tk_expect_tok
d6b4 : 8014             [ 3] 	bra df_tk_list_done
                             	; '*' means list procs
d6b6 :                       df_tk_list_procs
                             	; try and find the first proc
